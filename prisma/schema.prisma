generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  STUDENT
  TEACHER
  ADMIN
}

enum OtpPurpose {
  VERIFICATION
  RESET_PASSWORD
}

model EmailOtp {
  id        String   @id @default(uuid())
  email     String
  otp       String
  purpose   OtpPurpose @default(VERIFICATION)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
}


model User {
  id           String @id @default(uuid())
  email        String  @unique
  isVerified   Boolean @default(false)
  password     String
  username     String? @unique
  role         Role?   @default(STUDENT)

  adminProfile   AdminProfile?
  studentProfile StudentProfile?
  teacherProfile TeacherProfile?

  refreshToken String?
}

model AdminProfile {
  id          String @id @default(uuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id])

  permissions Json?
}

model StudentProfile {
  id              String             @id @default(uuid())
  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id])

  enrolledCourses CourseEnrollment[]
  assignmentSubmissions AssignmentSubmission[]
  mcqSubmissions MCQSubmission[]
}

model TeacherProfile {
  id      String   @id @default(uuid())
  userId  String   @unique
  user    User     @relation(fields: [userId], references: [id])

  courses Course[]
  assignments Assignment[]
  mcqs MCQ[]
}

model Course {
  id          String           @id @default(uuid())
  title       String
  description String?
  teacher     TeacherProfile   @relation(fields: [teacherId], references: [id])
  teacherId   String

  enrollments CourseEnrollment[]
  assignments Assignment[]
  mcqs MCQ[]

  createdAt   DateTime         @default(now())
}

model CourseEnrollment {
  id        String         @id @default(uuid())
  course    Course         @relation(fields: [courseId], references: [id])
  courseId  String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  studentId String

  enrolledAt DateTime      @default(now())
}

model Assignment {
  id          String        @id @default(uuid())
  course      Course        @relation(fields: [courseId], references: [id])
  courseId    String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  teacherId   String
  title       String
  description String?
  dueDate     DateTime

  submissions AssignmentSubmission[]
  createdAt   DateTime      @default(now())
}

model AssignmentSubmission {
  id           String         @id @default(uuid())
  assignment   Assignment     @relation(fields: [assignmentId], references: [id])
  assignmentId String
  student      StudentProfile @relation(fields: [studentId], references: [id])
  studentId    String
  submittedAt  DateTime       @default(now())
  fileUrl      String?        // optional file link
  grade        Float?
}

model MCQ {
  id          String        @id @default(uuid())
  course      Course        @relation(fields: [courseId], references: [id])
  courseId    String
  teacher     TeacherProfile @relation(fields: [teacherId], references: [id])
  teacherId   String
  question    String
  options     Json          // store options as array of strings
  correctAnswer String
  createdAt   DateTime      @default(now())

  submissions MCQSubmission[]
}

model MCQSubmission {
  id        String         @id @default(uuid())
  mcq       MCQ            @relation(fields: [mcqId], references: [id])
  mcqId     String
  student   StudentProfile @relation(fields: [studentId], references: [id])
  studentId String
  answer    String
  isCorrect Boolean?
  submittedAt DateTime      @default(now())
}

model BlacklistedToken {
  id        String   @id @default(uuid())
  token     String   @unique
  createdAt DateTime @default(now())
}